# Frontend environment variables. Vite exposes only VITE_* vars to the browser,
# and reads them at BUILD time. This value is a URL, not a secret.
#
# Local dev: leave as-is (or unset) to call the local backend on port 3000.
# Production (Netlify): set VITE_BACKEND_URL to your deployed backend, e.g.
#   https://your-backend.onrender.com
VITE_BACKEND_URL=http://localhost:3000
