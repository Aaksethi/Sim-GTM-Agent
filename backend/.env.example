# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Your Anthropic API key (from console.anthropic.com).
ANTHROPIC_API_KEY=

# --- Clay auth (preferred): auto-refresh, never expires manually -----------
# Run `node clay-auth.mjs` once to capture these into clay-oauth.json, then
# paste both values here (and into Render). The backend renews Clay's
# short-lived access token automatically from these.
CLAY_REFRESH_TOKEN=
CLAY_CLIENT_ID=

# --- Clay auth (legacy/manual): a raw OAuth bearer token -------------------
# Only used if the two vars above are NOT set. Expires ~hourly — avoid.
CLAY_MCP_TOKEN=

# Port the server listens on.
PORT=3000
